# ==========================================
# Root Docker Compose Configuration
# ==========================================

# ISE
ISE_VERSION=14.7

# Vivado
VIVADO_VERSION=2016.3

# Project workspace directory mapped to the container guest
WORKSPACE=/mnt/NTFS/ISE

# Path to your Xilinx.lic license file on the host (ISE only)
ISE_LICENSE_FILE=./dise/Xilinx.lic

# Move and/or restore .sim, .runs directories to Docker container to bypass synthesis/simulation process hangs
# AUTO_MIGRATE=true
# AUTO_RESTORE=true
