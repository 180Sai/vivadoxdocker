# Docker Compose project name
COMPOSE_PROJECT_NAME=dise

# Default ISE version
ISE_VERSION=14.7

# Path to ISE installer directory payload
INSTALLER_DIR=/mnt/NTFS/Downloads/Xilinx_ISE_DS_Lin_14.7_1015_1

# Path to directory containing config-ise.ini
