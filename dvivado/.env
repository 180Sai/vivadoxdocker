# ==========================================
# Docker Vivado Configuration File
# ==========================================

# Docker Compose project name
COMPOSE_PROJECT_NAME=dviwpk

# Default Vivado Version (e.g. 2016.2, 2016.3)
VIVADO_VERSION=2016.3

# Path to Vivado Installer Directory payload
INSTALLER_DIR=/mnt/NTFS/Downloads/Xilinx_Vivado_SDK_2016.3_1011_1

# Path to directory containing config-vivado.ini
CONFIG_DIR=.

# Project Workspace directory mapped to the container guest
WORKSPACE=/mnt/NTFS/ISE
